# ============================================================
# Nexus 통합 환경변수 예시 (.env.example)
# ============================================================
# 사용법:
#   1. cp .env.example .env
#   2. 아래 값들을 본인 환경에 맞게 채우기
#   3. 루트에서 `docker compose up -d` 로 모든 서비스 기동
#
# ⚠ .env 는 절대 git 에 commit 금지 (.gitignore 확인 필수)
# ============================================================


# ============================================================
# 공통 (모든 백엔드 모듈)
# ============================================================
JWT_SECRET=change-me-to-32-chars-or-more
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
EUREKA_SERVICE_URL=http://discovery:9090/eureka


# ============================================================
# DB — 모듈별 분리 (모놀리식 / 통계 MSA / POS MSA)
# ============================================================

# 모놀리식 DB (port 3306, db: nexus) — billing-batch / batch 도 공유
MONOLITH_DB_HOST=monolith-db
MONOLITH_DB_PORT=3306
MONOLITH_DB_NAME=nexus
MONOLITH_DB_USER=root
MONOLITH_DB_PASS=qwer1234

# 통계 MSA DB (port 3307, db: statistics)
STATS_DB_HOST=stats-db
STATS_DB_PORT=3307
STATS_DB_NAME=statistics
STATS_DB_USER=root
STATS_DB_PASS=qwer1234

# POS MSA DB (port 3308, db: pos)
POS_DB_HOST=pos-db
POS_DB_PORT=3308
POS_DB_NAME=pos
POS_DB_USER=root
POS_DB_PASS=qwer1234


# ============================================================
# Redis (통계 MSA 사전 집계)
# ============================================================
REDIS_HOST=redis
REDIS_PORT=6379


# ============================================================
# AI / OpenAI (모놀리식 — AI 자동 발주 / 챗봇 / 뉴스 요약)
# ============================================================
OPENAI_API_KEY=sk-...


# ============================================================
# MCP (Naver 뉴스 검색)
# ============================================================
MCP_NEWS_SERVER_PATH=./mcp/server.mjs
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=


# ============================================================
# AWS S3 (매장 / 메뉴 이미지 / 보고서 PDF)
# ============================================================
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_S3_STORE_BUCKET=nexus-store-dev
AWS_S3_MENU_BUCKET=nexus-menu-dev
AWS_S3_REPORT_BUCKET=nexus-report-dev
AWS_S3_STATIC=ap-northeast-2


# ============================================================
# Mail (Gmail SMTP — 비밀번호 찾기 등)
# Gmail 계정 + 앱 비밀번호: https://myaccount.google.com/apppasswords
# ============================================================
MAIL_ADDR=your-account@gmail.com
MAIL_PASS=


# ============================================================
# Billing / PortOne (정산 + 결제 게이트)
# ============================================================
PORTONE_SECRET_KEY=


# ============================================================
# Frontend (Vite)
# ============================================================
# 빌드 시 주입되어 dist/ 에 baked-in 됨
VITE_API_URL=/api


# ============================================================
# Docker Compose 외부 노출 포트 (호스트 → 컨테이너)
# ============================================================
# 충돌 시 호스트 포트만 변경 가능
DISCOVERY_PORT=9090
GATEWAY_PORT=8088
MONOLITH_PORT=8080
POS_PORT=8082
STATS_PORT=8081
BATCH_PORT=8083
FRONTEND_PORT=80
KAFKA_PORT=9092

# ============================================================
# Nexus Monolith - 로컬 개발용 환경변수 예시
# ============================================================
# 사용법:
#   1. cp .env.example .env
#   2. 아래 값들을 본인 환경에 맞게 채우기
#   3. IntelliJ Run Configuration 의 EnvFile plugin 에서 .env 지정
#      또는 docker-compose 의 env_file 로 주입
#
# ⚠ .env 는 절대 git 에 commit 금지 (.gitignore 확인 필수)
# ============================================================


# --- DataSource (MariaDB, 로컬 docker 3306) ---
DB_URL=jdbc:mariadb://localhost:3306/nexus
DB_USER=root
DB_PASS=qwer1234
DB_DRIVER=org.mariadb.jdbc.Driver


# --- Kafka (로컬 docker 9092, 또는 K8s 외부 노출 포트) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092


# --- AI / OpenAI (gpt-4o 사용, billing 발생 주의) ---
OPENAI_API_KEY=sk-...


# --- MCP (Naver 뉴스 검색용 MCP 서버) ---
MCP_NEWS_SERVER_PATH=./mcp/server.mjs
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=


# --- AWS S3 (매장/메뉴 이미지, 보고서 PDF 저장) ---
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_S3_STORE_BUCKET=nexus-store-dev
AWS_S3_MENU_BUCKET=nexus-menu-dev
AWS_S3_REPORT_BUCKET=nexus-report-dev
AWS_S3_STATIC=ap-northeast-2


# --- Mail (Gmail SMTP, 비밀번호 찾기 등) ---
# Gmail 계정 + 앱 비밀번호 (https://myaccount.google.com/apppasswords)
MAIL_ADDR=your-account@gmail.com
MAIL_PASS=


# --- Billing (정산 / PortOne 결제 처리) ---
SECRET_KEY=


# --- Eureka (Service Discovery) ---
# default: http://localhost:8761/eureka — 로컬 Eureka 띄우면 생략 가능
# EUREKA_SERVICE_URL=http://localhost:8761/eureka

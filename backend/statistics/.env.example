# ============================================================
# Nexus Statistics MSA - 로컬 개발용 환경변수 예시
# ============================================================
# 사용법:
#   1. cp .env.example .env
#   2. 아래 값들을 본인 환경에 맞게 채우기
#   3. IntelliJ Run Configuration 의 EnvFile plugin 에서 .env 지정
#      또는 docker-compose 의 env_file 로 주입
#
# ⚠ .env 는 절대 git 에 commit 금지 (.gitignore 확인 필수)
# ============================================================


# --- DataSource (통계 MSA 전용 MariaDB, 로컬 docker 3307) ---
# 모놀리식 DB (3306) 와 분리 — 통계 MSA 자체 DB 사용
DB_URL=jdbc:mariadb://localhost:3307/nexus
DB_USER=root
DB_PASS=qwer1234
DB_DRIVER=org.mariadb.jdbc.Driver


# --- SQL Init Mode ---
# default: always (schema.sql 의 shedlock 테이블 자동 생성)
# 운영 시 never 로 가능
# SQL_INIT_MODE=always


# --- Kafka (로컬 docker 9092) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Kafka Consumer Group ID
# default (dev): statistics-dev — prod 에서는 statistics-prod
# KAFKA_GROUP_ID=statistics-dev


# --- Redis (로컬 docker single 6379) ---
# 운영(prod) 은 Redis Cluster (Master 3 + Slave 3) 사용 — REDIS_CLUSTER_NODES 로 설정
# default: localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379

# 운영 환경(prod) 전용 — K8s ConfigMap 에서 주입
# REDIS_CLUSTER_NODES=redis-cluster-0.redis-cluster-service:6379,redis-cluster-1.redis-cluster-service:6379,...


# --- Eureka (Service Discovery) ---
# default: http://localhost:8761/eureka — 로컬 Eureka 띄우면 생략 가능
# EUREKA_SERVICE_URL=http://localhost:8761/eureka

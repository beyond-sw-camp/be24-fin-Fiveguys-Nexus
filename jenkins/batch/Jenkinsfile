pipeline {
    // Jenkins 에이전트를 K8s Pod로 실행 (빌드용 컨테이너 2개를 하나의 Pod에 구성)
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
spec:
  serviceAccountName: jenkins
  containers:
  - name: gradle                                    # Java 빌드용 (bootJar)
    image: eclipse-temurin:17-jdk-alpine
    command: ['sleep', 'infinity']
  - name: kaniko                                    # Docker 이미지 빌드 & Push용 (Docker 데몬 불필요)
    image: gcr.io/kaniko-project/executor:debug
    command: ['sleep', 'infinity']
"""
        }
    }

    triggers {
        githubPush()
    }

    environment {
        IMAGE_REPO = 'jaehyuklee071/nexusbatch'     // Docker Hub 이미지 저장소
    }

    stages {
        // 소스코드 체크아웃
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        // Spring Boot JAR 빌드 (batch 모듈)
        stage('Build JAR') {
            when {
                changeset "backend/batch/**"        // backend/batch/ 경로 변경 시에만 실행
            }
            steps {
                container('gradle') {
                    dir('backend') {
                        sh 'chmod +x gradlew && ./gradlew :batch:bootJar -x test'
                    }
                }
            }
        }

        // Docker 이미지 빌드 및 Docker Hub Push
        stage('Build & Push Docker Image') {
            when {
                changeset "backend/batch/**"        // backend/batch/ 경로 변경 시에만 실행
            }
            steps {
                container('kaniko') {
                    withCredentials([usernamePassword(
                        credentialsId: 'dockerhub-batch-credentials',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )]) {
                        sh """
                            AUTH=\$(printf "%s:%s" "\$DOCKER_USER" "\$DOCKER_PASS" | base64 | tr -d '\\n')
                            mkdir -p /kaniko/.docker
                            printf '{"auths":{"https://index.docker.io/v1/":{"auth":"%s"}}}' "\$AUTH" > /kaniko/.docker/config.json
                            # 빌드번호 태그 + latest 태그로 Push
                            /kaniko/executor \\
                                --context=\$WORKSPACE \\
                                --dockerfile=\$WORKSPACE/docker/batch/Dockerfile \\
                                --destination=${IMAGE_REPO}:${BUILD_NUMBER} \\
                                --destination=${IMAGE_REPO}:latest
                        """
                    }
                }
            }
        }
        // K8s 재배포 불필요
        // CronJob의 imagePullPolicy: Always + latest 태그로 인해
        // 다음 실행 시 자동으로 새 이미지를 Pull함
    }
}

pipeline {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: dind
    image: docker:24-dind
    securityContext:
      privileged: true
    env:
    - name: DOCKER_TLS_CERTDIR
      value: ""
    volumeMounts:
    - name: docker-storage
      mountPath: /var/lib/docker
  - name: kubectl
    image: bitnami/kubectl:latest
    command: ['sleep', 'infinity']
    securityContext:
      runAsUser: 0
  volumes:
  - name: docker-storage
    emptyDir: {}
"""
        }
    }

    environment {
        IMAGE_NAME    = 'deatytim/nexus-frontend'
        IMAGE_TAG     = "${env.BUILD_NUMBER}"
        K8S_NAMESPACE = 'default'
        SVC_NAME      = 'nexus-frontend-svc'
        DEPLOY_TMPL   = 'k8s/frontend/deployment.yaml'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Check Changes') {
            steps {
                script {
                    def changes = currentBuild.changeSets
                        .collectMany { it.items }
                        .collectMany { it.affectedFiles*.path }
                    echo "Changed files: ${changes}"
                    def relevant = changes.any {
                        it.startsWith('frontend/') ||
                        it.startsWith('docker/frontend/') ||
                        it.startsWith('k8s/frontend/')
                    }
                    if (!relevant) {
                        currentBuild.result = 'NOT_BUILT'
                        error('frontend 관련 변경 없음 — 파이프라인 스킵')
                    }
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                container('dind') {
                    sh """
                        until docker info > /dev/null 2>&1; do sleep 2; done
                        docker build -f docker/frontend/Dockerfile -t ${IMAGE_NAME}:${IMAGE_TAG} .
                    """
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                container('dind') {
                    withCredentials([usernamePassword(
                        credentialsId: 'dockerhub-credentials',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )]) {
                        sh """
                            echo \$DOCKER_PASS | docker login -u \$DOCKER_USER --password-stdin
                            docker push ${IMAGE_NAME}:${IMAGE_TAG}
                            docker tag  ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:latest
                            docker push ${IMAGE_NAME}:latest
                        """
                    }
                }
            }
        }

        stage('Determine Blue/Green Color') {
            steps {
                container('kubectl') {
                    script {
                        def cur = sh(
                            script: "kubectl get svc ${SVC_NAME} -n ${K8S_NAMESPACE} -o jsonpath='{.spec.selector.color}' 2>/dev/null || echo 'blue'",
                            returnStdout: true
                        ).trim()
                        env.CURRENT_COLOR = cur ?: 'blue'
                        env.NEW_COLOR     = (env.CURRENT_COLOR == 'blue') ? 'green' : 'blue'
                        echo "Active: ${env.CURRENT_COLOR}  →  Deploying to: ${env.NEW_COLOR}"
                    }
                }
            }
        }

        stage('Deploy Standby') {
            steps {
                container('kubectl') {
                    sh """
                        sed -e 's/{{COLOR}}/${env.NEW_COLOR}/g' \
                            -e 's/{{IMAGE_TAG}}/${IMAGE_TAG}/g' \
                            ${DEPLOY_TMPL} | kubectl apply -n ${K8S_NAMESPACE} -f -
                        kubectl rollout status deployment/nexus-frontend-${env.NEW_COLOR} \
                            -n ${K8S_NAMESPACE} --timeout=180s
                    """
                }
            }
        }

        stage('Switch Traffic') {
            steps {
                container('kubectl') {
                    sh """
                        kubectl patch svc ${SVC_NAME} -n ${K8S_NAMESPACE} \
                            -p '{"spec":{"selector":{"color":"${env.NEW_COLOR}"}}}'
                    """
                    echo "Traffic switched to ${env.NEW_COLOR}"
                }
            }
        }
    }

    post {
        success {
            echo "✅ Frontend deployed (${env.NEW_COLOR}) — image: ${IMAGE_NAME}:${IMAGE_TAG}"
        }
        failure {
            echo "❌ Deploy failed. Traffic still on ${env.CURRENT_COLOR}"
        }
        always {
            container('dind') {
                sh "docker logout || true"
                sh "docker rmi ${IMAGE_NAME}:${IMAGE_TAG} || true"
            }
        }
    }
}
